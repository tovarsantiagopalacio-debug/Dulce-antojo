# ─── BASE DE DATOS ────────────────────────────────────────────────────────────
# Cadena de conexión a MongoDB Atlas (nunca uses localhost en producción)
MONGO_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── AUTENTICACIÓN ────────────────────────────────────────────────────────────
# Secreto para firmar los JWT — genera uno con:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<minimo-64-caracteres-aleatorios>

# ─── SERVIDOR ─────────────────────────────────────────────────────────────────
# Puerto del servidor (Railway lo asigna automáticamente en producción)
PORT=3000

# Entorno de ejecución
NODE_ENV=production

# URL pública del app (usada en emails de recuperación de contraseña y CORS)
APP_URL=https://tu-dominio.up.railway.app

# ─── CLOUDINARY (subida de imágenes) ──────────────────────────────────────────
# Crea una cuenta en https://cloudinary.com y copia tus credenciales
CLOUDINARY_CLOUD_NAME=<tu-cloud-name>
CLOUDINARY_API_KEY=<tu-api-key>
CLOUDINARY_API_SECRET=<tu-api-secret>

# ─── EMAIL (recuperación de contraseña) ───────────────────────────────────────
# Usa una cuenta Gmail con contraseña de aplicación (no tu contraseña normal)
# Guía: https://support.google.com/accounts/answer/185833
EMAIL_USER=tucorreo@gmail.com
EMAIL_PASS=<contraseña-de-aplicacion-gmail>
EMAIL_FROM=Dulce Antojo <tucorreo@gmail.com>

# ─── ADMIN (solo para ejecutar seed-admin.js) ─────────────────────────────────
# Contraseña del usuario administrador — solo necesaria al ejecutar npm run seed:admin
ADMIN_EMAIL=admin@dulceantojo.com
ADMIN_PASSWORD=<contraseña-segura-del-admin>
ADMIN_NAME=Administrador
